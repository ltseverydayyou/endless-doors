end;
local function gmDoor(idx)
	local r = Rooms:FindFirstChild("Room" .. idx);
	if not r then
		return nil;
	end;
	if idx == Values.RoomsNumber.Value then
		return ED_tbl.getSafeDoorForCurrentRoom();
	end;
