local function runGodMode()
	if greedActive then
		gmNote("Greed is active, try again later.", 4);
		return;
	end;
	local v = Values.RoomsNumber.Value;
	if type(v) ~= "number" then
		return;
	end;
	local needKey = gmNeedKey(v);
	local hasLever = gmHasLever and gmHasLever(v);
	if needKey then
		local ok = gmAcquireKey(v);
		if not ok then
			gmNote("Failed to get key for this room.", 4);
			return;
		end;
	end;
	if hasLever then
		local ok = gmUseLever(v);
		if not ok then
			gmNote("Failed to use lever for this room.", 4);
			return;
		end;
	end;
	local availBack = gmAvail(v);
	if not availBack then
		gmNote("Open more doors before using God Mode.", 4);
		return;
	end;
	local backIdx = gmPrevRoom(v);
	if not backIdx then
		gmNote("Open more doors before using God Mode.", 4);
		return;
	end;
	local w = gmWard(backIdx);
	if not w then
		gmNote("No wardrobe found in nearby rooms.", 4);
		return;
	end;
	local d = gmDoor(v);
	if not d then
		gmNote("No safe door found (void door?).", 4);
		return;
	end;
	local ch = LocalPlayer.Character;
	if not ch then
		ch = LocalPlayer.CharacterAdded:Wait();
	end;
	if not ch then
		return;
	end;
	local hVal = ch:FindFirstChild("Hiding");
	if hVal and hVal.Value then
		gmNote("You are already hiding.", 3);
		return;
	end;
	ch:PivotTo(d:GetPivot());
	gmDisconnectCloset();
	local oldVal = curRoomVal.Value;
	gmRoomValConn = (curRoomVal:GetPropertyChangedSignal("Value")):Connect(function()
		if curRoomVal.Value ~= oldVal then
			task.defer(function()
				gmWatchCloset(v, backIdx, w);
			end);
		end;
	end);
	gmOpenDoor(d);
	task.spawn(function()
		local p = LocalPlayer;
		local c = p.Character or p.CharacterAdded:Wait();
		local hid = c and c:FindFirstChild("Hiding");
		repeat
			task.wait();
			c = p.Character or c;
			hid = c and c:FindFirstChild("Hiding");
		until not scriptRunning or hid and hid.Value or (not c);
		if not (hid and hid.Value) then
			return;
		end;
		gmNote("Hidden, holding...", 3);
		while scriptRunning and hid and hid.Value do
			local door = gmDoor(v);
			if door and door.Parent and c then
				c:PivotTo(door:GetPivot());
			end;
			task.wait(0.1);
			c = p.Character or c;
			hid = c and c:FindFirstChild("Hiding");
		end;
	end);
end;
