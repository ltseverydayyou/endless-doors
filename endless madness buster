local RoomTracker = (function()
	local roomItemCache = {};
	local trackedParts = {
		roomkey = {},
		bit = {},
		lever = {},
		battery = {}
	};
	local itemRoomIndex = {};
	local function roomKey(room)
		return room and room.Name;
	end;
	local function registerPart(kind, inst)
		local set = trackedParts[kind];
		if set and inst then
			set[inst] = true;
		end;
	end;
	local function unregisterPart(inst)
		for _, set in pairs(trackedParts) do
			set[inst] = nil;
		end;
	end;
	local function cleanedList(kind)
		local set = trackedParts[kind];
		if not set then
			return {};
		end;
		local list = {};
		for inst in pairs(set) do
			if inst and inst.Parent then
				list[(#list) + 1] = inst;
			else
				set[inst] = nil;
			end;
		end;
		return list;
	end;
	local function findRoom(inst)
		local current = inst;
		while current and current ~= Rooms do
			if current.Parent == Rooms and current:IsA("Model") and current.Name:match("^Room") then
				return current;
			end;
			current = current.Parent;
		end;
		return nil;
	end;
	local function setRoomValue(room, field, inst)
		local key = roomKey(room);
		if not key then
			return;
		end;
		local cache = roomItemCache[key];
		if not cache then
			cache = {
				room = room
			};
			roomItemCache[key] = cache;
		else
			cache.room = room;
		end;
		if field == "gateLever" then
			local current = cache.gateLever;
			if current and current.Parent and current:IsA("Model") and (not inst:IsA("Model")) then
				return;
			end;
		end;
		cache[field] = inst;
	end;
	local function clearRoomValue(roomName, inst)
		local cache = roomName and roomItemCache[roomName];
		if not cache then
			return;
		end;
		if cache.roomKey == inst then
			cache.roomKey = nil;
		end;
		if cache.gateLever == inst then
			cache.gateLever = nil;
		end;
	end;
	local function processAdded(inst, room)
		room = room or findRoom(inst);
		if not room then
			return;
		end;
		local lower = inst.Name:lower();
		if inst:IsA("Model") then
			if lower == "roomkey" then
				itemRoomIndex[inst] = room.Name;
				registerPart("roomkey", inst);
				setRoomValue(room, "roomKey", inst);
			elseif lower == "gatelever" or inst.Name == "GateLever" then
				itemRoomIndex[inst] = room.Name;
				setRoomValue(room, "gateLever", inst);
			end;
		elseif inst:IsA("BasePart") then
			if lower == "bit" then
				itemRoomIndex[inst] = room.Name;
				registerPart("bit", inst);
			elseif lower == "lever" or lower == "battery" then
				itemRoomIndex[inst] = room.Name;
				registerPart(lower, inst);
			elseif lower == "gatelever" then
				itemRoomIndex[inst] = room.Name;
				setRoomValue(room, "gateLever", inst);
			elseif inst.Parent and inst.Parent:IsA("Model") and inst.Parent.Name:lower() == "roomkey" then
				local holder = inst.Parent;
				itemRoomIndex[holder] = room.Name;
				registerPart("roomkey", holder);
				setRoomValue(room, "roomKey", holder);
			end;
		end;
	end;
	local function processRemoved(inst)
		unregisterPart(inst);
		local roomName = itemRoomIndex[inst];
		itemRoomIndex[inst] = nil;
		if roomName then
			clearRoomValue(roomName, inst);
		else
			local room = findRoom(inst);
			if room then
				clearRoomValue(room.Name, inst);
			end;
		end;
	end;
	local function indexRoom(room)
		if not (room and room:IsA("Model")) then
			return;
		end;
		for _, desc in ipairs(room:GetDescendants()) do
			processAdded(desc, room);
		end;
	end;
	local function getRoomTarget(room, field)
		if not room then
			return nil;
		end;
		local cache = roomItemCache[room.Name];
		if not cache then
			return nil;
		end;
		local inst = cache[field];
		if inst and inst.Parent then
			return inst;
		end;
		cache[field] = nil;
		return nil;
	end;
	local function init()
		for _, room in ipairs(Rooms:GetChildren()) do
			indexRoom(room);
		end;
		ED_tbl.trackConnection(Rooms.ChildAdded:Connect(function(room)
			if room and room:IsA("Model") and room.Name:match("^Room") then
				indexRoom(room);
			end;
		end));
		ED_tbl.trackConnection(Rooms.DescendantAdded:Connect(processAdded));
		ED_tbl.trackConnection(Rooms.DescendantRemoving:Connect(processRemoved));
	end;
	init();
	return {
		getRoomTarget = getRoomTarget,
		getTracked = function(kind)
			return cleanedList(kind);
		end,
		clear = function()
			roomItemCache = {};
			itemRoomIndex = {};
			for name in pairs(trackedParts) do
				trackedParts[name] = {};
			end;
		end
	};
end)();
ED_tbl.hasVoidWindOnDoor = function(doorModel)
	if not (doorModel and doorModel:IsA("Model")) then
		return false;
	end;
	local voidCount = 0;
	local hasVoidSound = false;
	for _, c in ipairs(doorModel:GetDescendants()) do
		local n = (c.Name or ""):lower();
		if n:find("void") then
			voidCount += 1;
			if c:IsA("Sound") then
				hasVoidSound = true;
			end;
		end;
		if c:IsA("Sound") then
			local sid = "";
			local ok, v = pcall(function()
				return c.SoundId;
			end);
			if ok and type(v) == "string" then
				sid = v:lower();
				if sid:find("void") then
					hasVoidSound = true;
				end;
			end;
		end;
	end;
	if hasVoidSound then
		return true;
	end;
	return voidCount >= 2;
end;
