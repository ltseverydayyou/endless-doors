local function gmUseLever(idx)
	local r = Rooms:FindFirstChild("Room" .. idx);
	if not r then
		return false;
	end;
	local gateLever = RoomTracker.getRoomTarget(r, "gateLever");
	if not gateLever or (not gateLever.Parent) then
		return false;
	end;
	local target = gateLever;
	if gateLever:IsA("Model") then
		target = gateLever:FindFirstChild("LeverGoal") or gateLever:FindFirstChild("Lever") or gateLever;
	end;
	local pp = gateLever:FindFirstChildWhichIsA("ProximityPrompt", true);
	if not pp then
		return false;
	end;
	local ch = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait();
