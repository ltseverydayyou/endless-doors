local function gmNeedKey(idx)
	local r = Rooms:FindFirstChild("Room" .. idx);
	if not r then
		return false;
	end;
	local key = RoomTracker.getRoomTarget(r, "roomKey");
	if not key then
		return false;
	end;
	local ch = LocalPlayer.Character;
	if not ch then
		return true;
	end;
	local vals = ch:FindFirstChild("Values");
	local hk = vals and vals:FindFirstChild("HasKey");
	if hk and hk.Value then
		return false;
	end;
	return true;
end;
local function gmAcquireKey(idx)
	local r = Rooms:FindFirstChild("Room" .. idx);
	if not r then
		return false;
	end;
	local ch = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait();
	if not ch then
		return false;
	end;
	local vals = ch:FindFirstChild("Values");
	local hk = vals and vals:FindFirstChild("HasKey");
	if hk and hk.Value then
		return true;
	end;
	local key = RoomTracker.getRoomTarget(r, "roomKey");
	if not key or (not key.Parent) then
		return hk and hk.Value or false;
	end;
	local base = ED_tbl.getBasePart(key);
	if base then
		ch:PivotTo(base.CFrame);
	end;
	local pp = WaitClass(key, "ProximityPrompt", 0.5) or key:FindFirstChildWhichIsA("ProximityPrompt", true);
	if not pp then
		return hk and hk.Value or false;
	end;
	local got = hk and hk.Value or false;
	local conn;
	if hk then
		conn = (hk:GetPropertyChangedSignal("Value")):Connect(function()
			if hk.Value then
				got = true;
			end;
		end);
	end;
	local t0 = tick();
	while not got and tick() - t0 < 3 do
		if not (pp and pp.Parent) then
			key = RoomTracker.getRoomTarget(r, "roomKey");
			if not key or (not key.Parent) then
				break;
			end;
			pp = WaitClass(key, "ProximityPrompt", 1) or key:FindFirstChildWhichIsA("ProximityPrompt", true);
			if not pp then
				break;
			end;
		end;
		pcall(fireproximityprompt, pp);
		task.wait(0.08);
	end;
	if conn then
		conn:Disconnect();
	end;
	if hk and hk.Value then
		return true;
	end;
	return false;
end;
local function gmHasLever(idx)
	local r = Rooms:FindFirstChild("Room" .. idx);
	if not r then
		return false;
	end;
	local gateLever = RoomTracker.getRoomTarget(r, "gateLever");
